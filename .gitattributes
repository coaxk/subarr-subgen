# Patch-stack repo — line endings MUST be deterministic. Anything else
# breaks `git apply` (CRLF-encoded patches against LF source = nothing
# applies cleanly) and corrupts our byte-for-byte validation oracle.
#
# Everything checked out as LF on every platform, no exceptions.

*           text=auto eol=lf

*.py        text eol=lf
*.sh        text eol=lf
*.patch     text eol=lf
*.diff      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf

Dockerfile  text eol=lf
LICENSE     text eol=lf
NOTICE      text eol=lf

# Binary fixtures stay binary.
*.mkv       binary
*.mp4       binary
*.bin       binary
*.png       binary
*.jpg       binary
