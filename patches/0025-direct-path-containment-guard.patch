         return fullpath.replace(path_mapping_from, path_mapping_to)
     return fullpath
 
+
+# [PATCH 0025 / subarr-subgen #13] Containment guard for the path-accepting
+# endpoints (/asr ?path=, /batch ?directory=, /detect_language_robust ?path=).
+# They run unauthenticated on the LAN; without this, POST /asr?path=/proc/1/environ
+# reads container secrets and /batch?directory=/ walks the whole filesystem.
+# Restrict accessed paths to a realpath allowlist (SUBGEN_PATH_ALLOWLIST,
+# colon-separated, default "/media"). os.path.realpath is symlink-safe, so an
+# in-media symlink to /etc is rejected too. Empty allowlist disables the check.
+_subgen_path_allowlist = [
+    os.path.realpath(p.strip())
+    for p in os.environ.get("SUBGEN_PATH_ALLOWLIST", "/media").split(":")
+    if p.strip()
+]
+
+
+def path_is_allowed(fullpath):
+    if not _subgen_path_allowlist:
+        return True
+    try:
+        rp = os.path.realpath(fullpath)
+    except (OSError, ValueError):
+        return False
+    return any(rp == root or rp.startswith(root + os.sep) for root in _subgen_path_allowlist)
+
+
