diff --git a/subgen.py b/subgen.py
index 33a8342..5f34e89 100644
--- a/subgen.py
+++ b/subgen.py
@@ -2,7 +2,7 @@ subgen_version = '2026.05.3'
 # [v4.3 PATCH] subarr-subgen patch-stack revision, surfaced via /queue so subarr
