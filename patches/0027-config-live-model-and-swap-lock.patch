From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: s <s@l>
Date: Wed, 24 Jun 2026 14:13:09 +1000
Subject: [PATCH] 0027: /config polish + #17 detect_language_track capability

---
 subgen.py | 17 ++++++++++++++++-
 1 file changed, 16 insertions(+), 1 deletion(-)

diff --git a/subgen.py b/subgen.py
index fa020bb..4dc0d14 100644
--- a/subgen.py
+++ b/subgen.py
@@ -345,7 +345,7 @@ model_cleanup_timer = None
 model_cleanup_lock = Lock()
 
 # Locks to ensure thread-safety during concurrent AI operations
-model_load_lock = Lock()
+model_load_lock = threading.RLock()  # [PATCH 0027 / #6] reentrant: /config swap holds it across start_model()
 active_direct_tasks = 0
 active_direct_tasks_lock = Lock()
 
@@ -736,6 +736,11 @@ def queue_status():
         "processing_count": len(processing),
         "idle": task_queue.is_idle(),
         "version": subgen_version,
+        # [PATCH 0027 / #6 item 2] live model/compute -- after a runtime /config
+        # swap the container env (WHISPER_MODEL) is stale, so subarr reads runtime
+        # truth here instead of Config.Env.
+        "model": whisper_model,
+        "compute_type": compute_type,
         # [v4.3 PATCH] subarr capability detection. subarr inspects these flags
         # on each integration health probe and degrades gracefully (e.g. doesn't
         # send audio_language_override to a subgen that wouldn't understand it).
@@ -743,6 +748,10 @@ def queue_status():
         "subarr_subgen_release_tag": subarr_subgen_release_tag,
         "capabilities": {
             "audio_language_override": True,
+            # [PATCH 0027 / #17] detect_language_robust accepts ?track=N (0-based
+            # audio stream) so subarr can language-detect a specific non-default
+            # track -- gates the Review "re-run on track N" confirmation UI.
+            "detect_language_track": True,
             # [v4.8 PATCH #88] per-request kwargs override on POST /batch
             # (?kwargs=<json>) — overrides global SUBGEN_KWARGS for one batch so
             # subarr's tuning-lab/tournament arena trials configs without env+restart.
@@ -855,6 +864,10 @@ def runtime_config(model_name: str = Query(None, alias="model"),
             "current_model": whisper_model, "current_compute_type": compute_type})
 
     prev_model_name, prev_compute = whisper_model, compute_type
+    # [PATCH 0027 / #6 item 3] hold model_load_lock across the WHOLE teardown+
+    # reload so a transcribe load can't interleave mid-swap (busy-check alone is
+    # non-atomic). RLock -> the nested start_model() acquire is fine.
+    model_load_lock.acquire()
     try:
         if model is not None:
             # Mirror the perform_model_cleanup() release idiom.
@@ -890,6 +903,8 @@ def runtime_config(model_name: str = Query(None, alias="model"),
             "detail": str(e)[:300],
             "rolled_back": rolled_back,
             "current_model": whisper_model, "current_compute_type": compute_type})
+    finally:
+        model_load_lock.release()
 
 
 # [v4.4 PATCH] Cancel a queued task by path. 200 with {cancelled: true}
