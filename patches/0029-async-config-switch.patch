+def _async_config_switch(model_name, compute):
+    """[PATCH 0029] Run _perform_config_switch on a background thread, recording
+    progress in _config_switch_state for GET /queue to surface."""
+    with _config_switch_lock:
+        _config_switch_state.update({
+            "state": "switching", "model": model_name or whisper_model,
+            "compute_type": compute or compute_type,
+            "reason": None, "detail": None, "rolled_back": None,
+        })
+    _status, body = _perform_config_switch(model_name, compute)
+    with _config_switch_lock:
+        _config_switch_state.update({
+            "state": "done" if body.get("ok") else "failed",
+            "model": body.get("model") or whisper_model,
+            "compute_type": body.get("compute_type") or compute_type,
+            "reason": body.get("reason"), "detail": body.get("detail"),
+            "rolled_back": body.get("rolled_back"),
+        })
+
+
+@app.post("/config")
+def runtime_config(model_name: str = Query(None, alias="model"),
+                   compute: str = Query(None, alias="compute_type"),
+                   wait: bool = Query(True)):
+    global whisper_model, compute_type, model
+    if model_name is None and compute is None:
+        return JSONResponse(status_code=400, content={
+            "ok": False, "reason": "nothing_to_change",
+            "current_model": whisper_model, "current_compute_type": compute_type})
+    if model_name is not None and model_name not in _ALLOWED_RUNTIME_MODELS:
+        return JSONResponse(status_code=400, content={
+            "ok": False, "reason": "unknown_model",
+            "current_model": whisper_model, "current_compute_type": compute_type})
+    if compute is not None and compute not in _ALLOWED_COMPUTE_TYPES:
+        return JSONResponse(status_code=400, content={
+            "ok": False, "reason": "unknown_compute_type",
+            "current_model": whisper_model, "current_compute_type": compute_type})
+    # Busy check mirrors perform_model_cleanup(): the queue must be idle
+    # (nothing queued, nothing processing) AND no direct (/asr-style)
+    # tasks in flight.
+    with active_direct_tasks_lock:
+        busy = (not task_queue.is_idle()) or active_direct_tasks > 0
+    if busy:
+        return JSONResponse(status_code=409, content={
+            "ok": False, "reason": "busy",
+            "detail": "jobs queued or processing; retry when idle",
+            "current_model": whisper_model, "current_compute_type": compute_type})
+
+    # [PATCH 0029 / #6 item 1] async opt-in: ?wait=false kicks the (slow, possibly
+    # minutes-long) switch on a background thread + returns 202; the client polls
+    # GET /queue.config_switch for completion. Default wait=true keeps the
+    # synchronous contract (backward-compatible with pre-async_config subarr).
+    if not wait:
+        with _config_switch_lock:
+            if _config_switch_state.get("state") == "switching":
+                return JSONResponse(status_code=409, content={
+                    "ok": False, "reason": "switch_in_progress",
+                    "current_model": whisper_model, "current_compute_type": compute_type})
+        threading.Thread(target=_async_config_switch, args=(model_name, compute), daemon=True).start()
+        return JSONResponse(status_code=202, content={
+            "status": "switching", "model": model_name or whisper_model,
+            "compute_type": compute or compute_type})
+    status_code, body = _perform_config_switch(model_name, compute)
+    return body if status_code == 200 else JSONResponse(status_code=status_code, content=body)
+
+
