     result = transcribe_existing(
         directory, LanguageCode.from_string(forceLanguage), reverse,
         audio_language_override=LanguageCode.from_string(audio_language_override)
             if audio_language_override else None,
         kwargs_override=kwargs_override,
         task_override=task_override,
+        ignore_forced_override=True if ignore_forced else None,
     )
     status = 404 if (not isinstance(result, dict) or result.get("walked", 0) == 0) else 200
     return JSONResponse(content=result, status_code=status)
