             "concurrent_transcriptions": concurrent_transcriptions,
+            # [v4.15 PATCH #317] subgen honours a per-REQUEST `ignore_forced`
+            # flag on POST /batch (overrides the global IGNORE_FORCED_SUBTITLES
+            # for that one job). subarr gates its "transcribe a full sub anyway"
+            # action on this so it never sends the flag to a subgen that would
+            # silently drop it and re-skip the forced-only file.
+            "request_ignore_forced": True,
         },
     }
 
